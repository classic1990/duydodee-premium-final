{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "globals": {
    "Chart": "readonly",
    "lucide": "readonly",
    "goToDiscoveryPage": "writable",
    "closeEditModal": "writable"
  },
  "plugins": [
    "html"
  ],
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "no-empty": "off",
    "no-useless-escape": "off",
    "semi": ["error", "always"],
    "quotes": ["error", "single"]
  }
}
