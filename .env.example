# PRODUCTION ENVIRONMENT CONFIGURATION
# Copy this file to .env.local and modify values for production

# Firebase Production Configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=duydodee.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=duydodee
VITE_FIREBASE_STORAGE_BUCKET=duydodee.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Site Configuration
VITE_SITE_URL=https://duydodee.web.app
VITE_SITE_NAME=DUYDODEE PREMIUM

# Admin Configuration (Production Admins)
# VITE_ADMIN_EMAILS should NOT be used for authorization - use Firebase custom claims instead

# Analytics Configuration
VITE_GA_TRACKING_ID=G-XXXXXXXXXX
VITE_ENABLE_ANALYTICS=true

# Sentry (Production Environment)
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
VITE_SENTRY_ENVIRONMENT=production
VITE_ENABLE_ERROR_MONITORING=true

# Feature Flags (Production)
VITE_ENABLE_DEBUG=false
VITE_ENABLE_MOCK_DATA=false

# AI Integration (Production)
VITE_AI_PROVIDER=anthropic
VITE_AI_API_KEY=your_ai_api_key_here
VITE_AI_MODEL=claude-3-opus-20240229
VITE_AI_ENDPOINT=
