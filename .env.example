# Environment Variables Template
# DO NOT COMMIT REAL CREDENTIALS - Copy this file to .env.local and fill in your values

# Firebase Configuration
# Note: In production, use Firebase automatic config via firebase-tools
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=duydodeesport.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=duydodeesport
VITE_FIREBASE_STORAGE_BUCKET=duydodeesport.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=30514101130
VITE_FIREBASE_APP_ID=1:30514101130:web:1ec44f2b09367468132e49
VITE_FIREBASE_MEASUREMENT_ID=G-7EC2RQZH22

# Admin Configuration
# Comma-separated list of admin emails
VITE_ADMIN_EMAILS=admin@example.com,duyclassic191@gmail.com

# Site Configuration
VITE_SITE_URL=https://duydodeesport.web.app
VITE_SITE_NAME=DUYดูDEE PREMIUM

# Analytics Configuration
VITE_GA_TRACKING_ID=G-XXXXXXXXXX
VITE_ENABLE_ANALYTICS=true

# Error Tracking (Sentry - Optional)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production

# Feature Flags
VITE_ENABLE_DEBUG=false
VITE_ENABLE_MOCK_DATA=false
