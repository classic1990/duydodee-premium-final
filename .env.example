# =====================================================
# DUYDODEE PREMIUM - ENVIRONMENT CONFIGURATION
# =====================================================
# Instructions:
# 1. Copy this file to .env.local for local development
# 2. Copy this file to .env.production for production
# 3. NEVER commit files containing real credentials
# 4. Required fields must be filled for the app to function
# =====================================================

# ================= FIREBASE CONFIGURATION =================
# Required: All fields are mandatory for Firebase to work
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=duydodeesport.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=duydodeesport
VITE_FIREBASE_STORAGE_BUCKET=duydodeesport.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=30514101130
VITE_FIREBASE_APP_ID=1:30514101130:web:1ec44f2b09367468132e49
VITE_FIREBASE_MEASUREMENT_ID=G-7EC2RQZH22

# ================= SITE CONFIGURATION =================
VITE_SITE_URL=https://duydodee.web.app
VITE_SITE_NAME=DUYDODEE PREMIUM
VITE_SITE_DESCRIPTION=แพลตฟอร์มสตรีมมิ่ง 4K HDR ระดับพรีเมียม
VITE_SITE_KEYWORDS=streaming,4K,HDR,movies,series,premium

# ================= ANALYTICS CONFIGURATION =================
VITE_GA_TRACKING_ID=G-XXXXXXXXXX
VITE_ENABLE_ANALYTICS=true

# ================= ERROR MONITORING =================
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
VITE_SENTRY_ENVIRONMENT=production
VITE_ENABLE_ERROR_MONITORING=true

# ================= FEATURE FLAGS =================
VITE_ENABLE_DEBUG=false
VITE_ENABLE_MOCK_DATA=false
VITE_ENABLE_PERFORMANCE_MONITORING=true

# ================= CONTENT CONFIGURATION =================
VITE_DEFAULT_PAGE_SIZE=12
VITE_MAX_RETRY_ATTEMPTS=3
VITE_API_TIMEOUT=30000

# ================= SEARCH CONFIGURATION =================
VITE_ALGOLIA_APP_ID=your_algolia_app_id
VITE_ALGOLIA_SEARCH_KEY=your_algolia_search_key
VITE_ALGOLIA_INDEX_NAME=duydodee_content

# ================= AI INTEGRATION (OPTIONAL) =================
VITE_AI_PROVIDER=anthropic
VITE_AI_API_KEY=your_ai_api_key_here
VITE_AI_MODEL=claude-3-opus-20240229
VITE_AI_ENDPOINT=
VITE_ENABLE_AI_FEATURES=false
