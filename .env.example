# Application Insights (Azure Monitoring)
VITE_APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=your_instrumentation_key;IngestionEndpoint=https://your-region.in.applicationinsights.azure.com/

# Firebase Configuration (Get from Firebase Console)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=duydodeesport.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=duydodeesport
VITE_FIREBASE_STORAGE_BUCKET=duydodeesport.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Firebase Admin SDK (For Node.js backend - NEVER expose this in frontend!)
FIREBASE_PRIVATE_KEY=your_private_key_from_service_account
FIREBASE_CLIENT_EMAIL=your_service_account_email

# Environment
NODE_ENV=development

# API Endpoints
VITE_API_URL=http://localhost:3000

# Feature Flags (Optional)
VITE_ENABLE_VIP_FEATURE=true
VITE_ENABLE_ANALYTICS=true
