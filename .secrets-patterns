# Secrets Patterns for Pre-commit Hook
# These patterns are checked in the pre-commit hook to prevent secrets from being committed

# Google API Keys
AIza[0-9A-Za-z\-_]{35,39}

# Firebase Keys
firebaseio\.com
firebaseapp\.com

# AWS Keys
AKIA[0-9A-Z]{16}
[0-9A-Z]{40}

# Stripe Keys
sk_live_[0-9A-Za-z]{24}
sk_test_[0-9A-Za-z]{24}

# GitHub Tokens
ghp_[A-Za-z0-9]{36}
gho_[A-Za-z0-9]{36}
ghu_[A-Za-z0-9]{36}
ghs_[A-Za-z0-9]{36}
ghr_[A-Za-z0-9]{36}

# Slack Tokens
xox[baprs]-[0-9A-Za-z\-]{12,34}

# Generic Secret Patterns
password\s*=\s*["'][^"\']+["']
api_key\s*=\s*["'][^"\']+["']
secret\s*=\s*["'][^"\']+["']
token\s*=\s*["'][^"\']+["']
private_key\s*=\s*["'][^"\']+["']
credentials\s*=\s*["'][^"\']+["']

# Private Key Blocks
-----BEGIN\s+RSA\s+PRIVATE\s+KEY-----
-----BEGIN\s+ECDSA\s+PRIVATE\s+KEY-----
-----BEGIN\s+PRIVATE\s+KEY-----
