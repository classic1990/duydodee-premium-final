rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- [ Helper Functions ] ---
    
    // ตรวจสอบว่าเข้าสู่ระบบหรือยัง
    function isSignedIn() {
      return request.auth != null;
    }

    // ตรวจสอบว่าเป็น Admin หรือไม่ (ตรวจสอบจาก Role ใน Database)
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'member') in ['admin', 'super-admin', 'master']
      );
    }

    // ตรวจสอบว่า user ไม่ได้ถูกแบน
    function isNotBanned() {
      return isSignedIn() && (
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBanned', false) == false
      );
    }

    // ตรวจสอบขนาดข้อมูล (ป้องกันข้อมูลใหญ่เกินไป)
    function isDataSizeValid() {
      return request.resource.data.size() < 100000; // 100KB limit
    }

    // --- [ Collection Rules ] ---

    // กฎสำหรับสไลด์แนะนำ (Hero Slides)
    match /hero_slides/{slideId} {
      allow read: if true; // ทุกคนดูได้
      allow write: if isAdmin() && isDataSizeValid(); // เฉพาะ Admin ที่เพิ่ม/แก้ไข/ลบ ได้
    }

    // กฎสำหรับภาพยนตร์ (Movies)
    match /movies/{movieId} {
      allow read: if true;
      allow update: if (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views'])) || (isAdmin() && isDataSizeValid());
      allow create: if isAdmin() && isDataSizeValid();
      allow delete: if isAdmin();
    }

    // กฎสำหรับซีรีส์ (Series) และตอนย่อย (Episodes)
    match /series/{seriesId} {
      allow read: if true;
      allow update: if (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views'])) || (isAdmin() && isDataSizeValid());
      allow create: if isAdmin() && isDataSizeValid();
      allow delete: if isAdmin();

      match /episodes/{epId} {
        allow read: if true;
        allow write: if isAdmin() && isDataSizeValid();
      }
    }

    // กฎสำหรับข้อมูลสมาชิก (Users)
    match /users/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId && isNotBanned());
      // ป้องกัน User แก้ไขฟิลด์ role ของตัวเอง
      allow create: if false; // ห้ามสร้าง user โดยตรง (ต้องผ่าน Firebase Auth)
      allow update: if isAdmin() || (
        isSignedIn() && 
        request.auth.uid == userId && 
        isNotBanned() &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isBanned', 'createdAt', 'uid']) &&
        isDataSizeValid()
      );
      allow delete: if isAdmin();
      
      match /history/{historyId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId && isNotBanned();
      }
    }

    // กฎสำหรับสถิติรายวัน (Daily Stats)
    match /daily_stats/{dateId} {
      allow read: if true;
      allow write: if isAdmin() && isDataSizeValid();
    }

    // กฎสำหรับบันทึกกิจกรรม (Activity Logs)
    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isDataSizeValid();
      allow update, delete: if false; // ห้ามแก้ไขหรือลบ Log
    }

    // กฎสำหรับตั้งค่าเว็บไซต์ (Site Settings)
    match /site_settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isDataSizeValid();
    }

    // กฎสำหรับประวัติการชำระเงิน VIP
    match /vip_payments/{paymentId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
      // บังคับ status เริ่มต้นเป็น pending และ userId ตรงกับผู้สร้าง
      allow create: if isSignedIn() && 
                     isNotBanned() &&
                     request.resource.data.status == 'pending' &&
                     request.resource.data.userId == request.auth.uid &&
                     isDataSizeValid();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
