rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 🛠️ Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['super-admin', 'admin', 'master'] ||
         exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // 👤 User Profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
      
      match /history/{historyId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /bookmarks/{bookmarkId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /watchlist/{watchlistId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // 🎬 Content Collections (Public read; signed-in users may only
    // increment the view counter and update ratings, nothing else)
    match /movies/{movieId} {
      allow read: if true;
      allow update: if isSignedIn() && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) ||
                                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'averageRating', 'totalReviews']));
    }

    match /series/{seriesId} {
      allow read: if true;
      allow update: if isSignedIn() && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) ||
                                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'averageRating', 'totalReviews']));
    }

    match /hero_slides/{slideId} {
      allow read: if true;
    }

    // 📊 Stats: Public read; signed-in users may create the daily doc and
    // only bump the view counter
    match /daily_stats/{statId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'lastUpdated']);
    }

    // 💳 VIP Payments: Admin read/write, user create
    match /vip_payments/{paymentId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && request.resource.data.status == 'pending';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 🎯 VIP Plans: Public read, Admin write
    match /vip_plans/{planId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // 🎫 Support Tickets: Admin read/write, user create
    match /support_tickets/{ticketId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']));
    }

    // ⭐ Reviews: Public read, signed-in users can create/edit own reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 📝 Activity Logs: Admin only
    match /activity_logs/{logId} {
      allow read, write: if isAdmin();
    }

    // 💬 Community Chat
    match /chat_messages/{messageId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isAdmin();
      allow update: if false;
    }

    // 📊 System Logs: Admin only
    match /system_logs/{logId} {
      allow read, write: if isAdmin();
    }

    // 🔒 Catch-all: Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
