rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🛠️ Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['super-admin', 'admin', 'master'] ||
         request.auth.token.email == 'duyclassic191@gmail.com');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // 👤 User Profiles: เจ้าของแก้ไขได้เอง แต่ทุกคนที่ Login แล้วเห็น Profile เบื้องต้นได้
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
      
      // 📜 Watch History: เฉพาะเจ้าของเท่านั้นที่จัดการได้
      match /history/{historyId} {
        allow read, write: if isOwner(userId);
      }
    }

    // 🎬 Content Collections: คนทั่วไปอ่านได้ แอดมินเท่านั้นที่เขียนได้
    match /movies/{movieId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /series/{seriesId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /hero_slides/{slideId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 📊 Stats: ต้องเข้าระบบถึงจะบันทึกสถิติได้
    match /daily_stats/{statId} {
      allow read, write: if isSignedIn();
    }

    // 🛡️ Activity Logs: ระบบบันทึกหลักฐานการทำงาน แอดมินเท่านั้นที่จัดการได้
    match /activity_logs/{logId} {
      allow read, write: if isAdmin();
    }

    // 💳 VIP Payments: แอดมินตรวจสอบได้เท่านั้น
    match /vip_payments/{paymentId} {
      allow read, write: if isAdmin();
    }
  }
}